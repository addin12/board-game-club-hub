# Supabase — enables persistent sessions + RSVPs.
# Leave these blank to use the in-memory store (dev only; resets on restart).
# The anon key is safe to expose to the browser by design; access is controlled
# by Supabase Row Level Security (RLS) policies.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
