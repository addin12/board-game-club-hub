# Supabase — enables persistent sessions + RSVPs.
# Leave these blank to use the in-memory store (dev only; resets on restart).
# The publishable/anon key is safe to expose to the browser by design; access is
# controlled by Supabase Row Level Security (RLS) policies.

NEXT_PUBLIC_SUPABASE_URL=
# Newer projects: the publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older projects use the anon JWT instead (either one works):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# BoardGameGeek XML API access token (required since 2025-07; apply at
# boardgamegeek.com/using_the_xml_api). SERVER-SIDE ONLY — note the lack of a
# NEXT_PUBLIC_ prefix so it never reaches the browser. Without it, live BGG
# fetches return 401 and the app falls back to baked-in demo data.
BGG_API_TOKEN=
